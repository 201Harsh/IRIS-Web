# ==============================
# 🌐 Server Configuration
# ==============================

# Base URL where your backend server runs
# Example (local): http://localhost:4000
NEXT_PUBLIC_SERVER_URL=http://localhost:4000

# Port on which the backend server will run
PORT=4000


# ==============================
# 🗄️ Database Configuration
# ==============================

# MongoDB connection string
# Format: mongodb://<host>:<port>/<database-name>
# Example (local): mongodb://localhost:27017/IRIS-AI
MONGO_URI=mongodb://localhost:27017/IRIS-AI


# ==============================
# 🌍 Client Configuration
# ==============================

# Frontend (client) URL
# Example (local React/Next app): http://localhost:3000
CLIENT_URL=http://localhost:3000


# ==============================
# 🔐 Authentication (JWT)
# ==============================

# Secret key used to sign access tokens
# ⚠️ Use a strong, random string in production
ACCESS_TOKEN_SECRET=your_access_token_secret_here

# Secret key used to sign refresh tokens
# ⚠️ Keep this secure and different from ACCESS_TOKEN_SECRET
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here

# Expiry time for access token
# Examples: 10m (10 minutes), 1h (1 hour)
ACCESS_TOKEN_EXPIRY=10m

# Expiry time for refresh token
# Examples: 30d (30 days), 7d (7 days)
REFRESH_TOKEN_EXPIRY=30d


# ==============================
# 🔑 OAuth (Google Login)
# ==============================

# Google OAuth Client ID
# Get this from Google Cloud Console
GOOGLE_CLIENT_ID=your_google_client_id_here

# Google OAuth Client Secret
# Keep this private and secure
GOOGLE_CLIENT_SECRET=your_google_client_secret_here